# Copy this file to `.env` and fill in real values.

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudflare R2
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com/<bucket>
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://<public-id>.r2.dev/<bucket>

# Cloudflare Workers AI (powers AI-assisted event descriptions and smart image tagging)
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_AI_TOKEN=your_workers_ai_api_token
# Optional model override. Defaults to @cf/meta/llama-3.3-70b-instruct-fp8-fast
# CF_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
# Optional vision LLM for smart image tagging.
# Defaults to @cf/meta/llama-3.2-11b-vision-instruct (campus-event tag vocabulary).
# CF_AI_VISION_LLM_MODEL=@cf/meta/llama-3.2-11b-vision-instruct
#
# IMPORTANT: Llama 3.2 Vision requires a one-time license-agreement request
# before it can be used. Run this once after setting CF_ACCOUNT_ID/CF_AI_TOKEN:
#   curl https://api.cloudflare.com/client/v4/accounts/$CF_ACCOUNT_ID/ai/run/@cf/meta/llama-3.2-11b-vision-instruct \
#     -X POST -H "Authorization: Bearer $CF_AI_TOKEN" \
#     -d '{"prompt":"agree"}'
#
# Optional ResNet override (kept for backward compatibility / future fallbacks)
# CF_AI_VISION_MODEL=@cf/microsoft/resnet-50
